      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98002' id='1' param='vert' removable='false' type-v2='layout-flow' w='99034' x='483' y='999'>
            <zone h='6866' id='3' type-v2='title' w='99034' x='483' y='999' />
            <zone fixed-size='139' h='17353' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99034' x='483' y='7865' />
            <zone h='73783' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99034' x='483' y='25218'>
              <flipboard active-id='4' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='OVERALL BUSINESS PERFORMANCE&#10;This view provides a high-level summary of overall sales, profit, quantity sold, and profit margin, along with trends and regional performance.' captured-sheet='Executive Overview' id='1'>
                    <capturedDeltas>
                      <dashboard name='Executive Overview'>
                        <zone id='30'>
                          <formatted-text>
                            <run bold='true' fontcolor='#59a14f' fontsize='24'>Æ </run>
                          </formatted-text>
                        </zone>
                      </dashboard>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='CATEGORY WISE SALES VS PROFIT ANALYSIS&#10;This view compares sales and profit across product categories to identify high-revenue and high-profit segments.' captured-sheet='sales vs profit cat' id='2' />
                  <story-point caption='CUSTOMER CONTRIBUTION &amp; DISCOUNT IMPACT&#10;This view highlights the contribution of top customers and shows how discount levels influence profitability at the order level.' captured-sheet='disc vs profit' id='3' />
                  <story-point caption='PROFITABILITY BY SHIPPING MODE&#10;This view analyzes profit across different shipping modes to evaluate logistics efficiency and cost impact.' captured-sheet='profit by shipping mode' id='4' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
